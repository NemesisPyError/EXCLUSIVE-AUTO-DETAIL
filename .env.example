# ============================================================
# Exclusive Auto Detail — Variables de Entorno
# Copiar a .env y completar los valores antes de ejecutar.
# ============================================================

# Entorno: development | production
FLASK_ENV=development

# Clave secreta de Flask (generar con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-string

# Base de datos MySQL
DB_USER=exclusive_user
DB_PASSWORD=secure_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=exclusive_autodetail

# Redis (obligatorio en FLASK_ENV=production)
# Development: no necesario, usa SimpleCache + memory://
# Production: redis://redis:6379/0 (docker) o redis://localhost:6379/0 (local)
REDIS_URL=

# SMTP para envío de emails (recuperación de contraseña, confirmaciones)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SENDER=noreply@exclusiveautodetail.com
MAIL_USE_TLS=true

# ProxyFix — cantidad de proxies de confianza entre el cliente y Gunicorn
# 0 = sin proxy (desarrollo local)
# 1 = un proxy (ej. Nginx)
# 2 = dos proxies (ej. Cloudflare + Nginx)
PROXY_COUNT=0
